        </ul>
      </div>
    </div>
    <!-- Bottom bar -->
    <div style="border-top:1px solid rgba(255,255,255,0.07);padding:1.5rem 0;display:flex;flex-wrap:wrap;gap:1rem;justify-content:space-between;align-items:center">
      <p style="color:#7A7D86;font-size:0.8125rem">{footer.legal.copyright}</p>
      <div style="display:flex;gap:1.5rem;flex-wrap:wrap">
        {footer.legal.links.map(l => (
          <a href={l.href} style="color:#7A7D86;font-size:0.8125rem;text-decoration:none;transition:color 0.2s" onmouseover="this.style.color='rgba(245,246,247,0.7)'" onmouseout="this.style.color='#7A7D86'">{l.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

