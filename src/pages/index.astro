            <a href={`mailto:${footer.contact.email}`} style="color:#9A9DA6;font-size:0.875rem;text-decoration:none" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#9A9DA6'">{footer.contact.email}</a>
