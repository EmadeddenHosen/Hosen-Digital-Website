<script>
  function toggleGreeter(btn) {
    const greeter = btn.closest('.greeter-alpha');
    const isOpen = greeter.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', isOpen);
    greeter.querySelector('.greeter-alpha__content-wrapper').setAttribute('aria-hidden', !isOpen);
    btn.setAttribute('aria-label', isOpen ? 'Close chat' : 'Open chat');
  }

  function toggleAcc(btn) {
    const body = btn.nextElementSibling;
    const isOpen = btn.classList.contains('open');
    document.querySelectorAll('.acc-trigger.open').forEach(b => {
      b.classList.remove('open');
      b.nextElementSibling.style.maxHeight = '0';
    });
    if (!isOpen) {
      btn.classList.add('open');
      body.style.maxHeight = body.scrollHeight + 'px';
    }
  }
</script>

</body>
</html>
